{
  "name": "mcp-lint",
  "version": "0.4.0",
  "description": "Lint MCP server tool schemas for cross-client compatibility + runtime preflight for agent tool calls",
  "type": "module",
  "bin": {
    "mcp-lint": "./dist/index.js"
  },
  "main": "./dist/core/engine.js",
  "types": "./dist/core/engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/engine.d.ts",
      "default": "./dist/core/engine.js"
    },
    "./preflight": {
      "types": "./dist/preflight/index.d.ts",
      "default": "./dist/preflight/index.js"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "default": "./dist/rules/index.js"
    }
  },
  "files": [
    "dist/",
    "examples/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lint",
    "schema",
    "validation",
    "preflight",
    "agent-safety",
    "policy",
    "guardrails"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
